REDIS_URL=redis://localhost:6379

# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Fallback LLM (used if primary fails)
FALLBACK_PROVIDER=anthropic
FALLBACK_MODEL=claude-haiku-4-5-20251001

# API keys (set the one matching your provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql://agent:changeme@localhost:5432/agent_tasty

# Whisper model size for voice transcription (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# MSSQL connection (external BI database with client master data)
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=

# HANDY CRM API (optional — for order history + visit frequency)
HANDY_BASE_URL=
HANDY_API_TOKEN=

# WhatsApp pairing (optional — set phone number for code-based auth instead of QR)
# PAIRING_NUMBER=
